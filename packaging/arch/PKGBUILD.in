pkgname=verbuno
pkgver=@VERSION@
pkgrel=1
pkgdesc='Native Linux AI translation client'
arch=('x86_64')
url='https://github.com/Trendorin/Verbuno'
license=('GPL-3.0-or-later')
depends=('glibc' 'gcc-libs' 'qt6-base' 'qt6-svg' 'qtkeychain-qt6')
makedepends=('cmake' 'ninja' 'qt6-tools')
provides=('translunix')
conflicts=('translunix')
replaces=('translunix')
options=('!debug')
source=("Verbuno-$pkgver-source.tar.xz::$url/releases/download/v$pkgver/Verbuno-$pkgver-source.tar.xz")
sha256sums=('@SOURCE_SHA256@')

build() {
  cmake -S "Verbuno-$pkgver" -B build -G Ninja \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DVERBUNO_BUILD_TESTS=ON \
    -DVERBUNO_REQUIRE_KEYCHAIN=ON
  cmake --build build
}

check() {
  ctest --test-dir build --output-on-failure
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}

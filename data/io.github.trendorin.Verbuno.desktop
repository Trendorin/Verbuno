[Desktop Entry]
Type=Application
Name=Verbuno
GenericName=AI Translator
Comment=Translate text through your own AI provider
Exec=verbuno --toggle
Icon=io.github.trendorin.Verbuno
Terminal=false
Categories=Utility;Office;Qt;
Keywords=translate;translation;language;OpenRouter;AI;LLM;
StartupNotify=false
StartupWMClass=Verbuno
X-GNOME-UsesNotifications=true
Actions=Window;Settings;

[Desktop Action Window]
Name=Open Verbuno
Exec=verbuno --show

[Desktop Action Settings]
Name=Settings
Exec=verbuno --settings
